<%# Renders one tournament with either "Picks TBD" or a bulleted list of the user's picks. %>
<%# Locals: tournament, pool, pick (optional), pool_tournament (optional — for bonus display) %>
<%= tournament.name %> (<%= tournament.starts_at&.strftime("%b %d") %>)
<div class="text-sm text-gray-500">Max Cut Made Bonus: <%= tournament.max_cut_made_bonus.positive? ? "$#{number_with_delimiter(tournament.max_cut_made_bonus.to_i)}" : "TBD" %></div>
<% if pick&.pick_golfers&.any? %>
  <ul class="list-disc list-inside ml-4 mt-1 space-y-0.5 text-gray-700">
    <% pick.pick_golfers.order(:slot).each do |pg| %>
      <% odds = pool_tournament&.pool_tournament_odds&.find { |o| o.golfer_id == pg.golfer_id }&.american_odds %>
      <li><%= golfer_name_with_bonus(pg.golfer&.name, odds, tournament: tournament) %></li>
    <% end %>
  </ul>
  <% unless tournament.picks_locked? %>
    <%= link_to "Edit", edit_pool_pick_path(pool, pick), class: "text-emerald-600 hover:underline text-sm mt-1 inline-block" %>
  <% end %>
<% else %>
  <p class="text-gray-500 text-sm mt-1">Picks TBD</p>
  <% if tournament.picks_open? %>
    <%= link_to "Make picks", new_pool_pick_path(pool, tournament_id: tournament.id), class: "inline-flex items-center rounded-md px-3 py-2 text-sm font-semibold bg-emerald-600 text-white shadow-sm hover:bg-emerald-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600 mt-2" %>
  <% else %>
    <span class="text-gray-500 text-sm mt-1 inline-block">
      Picks open on <%= l(tournament.picks_open_at.to_date, format: :long) %>
    </span>
  <% end %>
<% end %>
