<div class="max-w-md mx-auto border border-gray-200 rounded-lg p-6 bg-white shadow-sm">
  <h1 class="text-2xl font-bold text-gray-900 mb-2">Profile</h1>
  <p class="text-gray-600 text-sm mb-6">
    Enter your current GHIN handicap index (honor system). Used for on-course net games when those features go live.
  </p>

  <%= form_with model: @user, url: profile_path, method: :patch, local: true, class: "space-y-4" do |f| %>
    <% if @user.errors.any? %>
      <ul class="mb-4 p-4 bg-red-50 border border-red-200 text-red-800 rounded-lg list-disc list-inside">
        <% @user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    <% end %>
    <div>
      <%= f.label :ghin_handicap_index, "GHIN handicap index", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :ghin_handicap_index, step: 0.1, class: "w-full rounded border border-gray-300 px-3 py-2 focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500", placeholder: "e.g. 12.4" %>
      <p class="text-xs text-gray-500 mt-1">Leave blank if you prefer not to share. Range −54 to 54.</p>
    </div>
    <div>
      <%= f.submit "Save profile", class: "bg-emerald-600 text-white px-4 py-2 rounded hover:bg-emerald-700 font-medium" %>
    </div>
  <% end %>
</div>
